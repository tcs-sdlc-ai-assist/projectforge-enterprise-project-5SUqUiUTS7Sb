# ProjectForge Environment Configuration
# Copy this file to .env and fill in the values

# Secret key used for signing JWT tokens and other cryptographic operations
# Generate a strong random key, e.g.: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-to-a-random-secret-key

# Default admin account credentials (created on first startup if no admin exists)
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=changeme123

# Database connection URL
# For SQLite (default): sqlite+aiosqlite:///./projectforge.db
# For PostgreSQL: postgresql+asyncpg://user:password@localhost:5432/projectforge
DATABASE_URL=sqlite+aiosqlite:///./projectforge.db

# JWT token expiry duration in seconds (default: 3600 = 1 hour)
TOKEN_EXPIRY_SECONDS=3600